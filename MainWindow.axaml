<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NetworkAnalyzer.MainWindow"
        Title="Анализатор сетевых подключений"
        Width="950" Height="700"
        WindowStartupLocation="CenterScreen">

  <TabControl Margin="10">

    <!-- ===================== ВКЛАДКА 1: Сетевые интерфейсы ===================== -->
    <TabItem Header="Сетевые интерфейсы">
      <Grid ColumnDefinitions="300,10,*" Margin="5">

        <!-- Список интерфейсов -->
        <DockPanel Grid.Column="0">
          <TextBlock DockPanel.Dock="Top" Text="Интерфейсы:" FontWeight="Bold" Margin="0,0,0,5"/>
          <Button DockPanel.Dock="Bottom" Content="Обновить список"
                  Click="RefreshInterfaces_Click" Margin="0,5,0,0"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
          <ListBox Name="InterfacesListBox" SelectionChanged="InterfacesListBox_SelectionChanged"/>
        </DockPanel>

        <!-- Информация о выбранном интерфейсе -->
        <DockPanel Grid.Column="2">
          <TextBlock DockPanel.Dock="Top" Text="Информация об интерфейсе:" FontWeight="Bold" Margin="0,0,0,5"/>
          <TextBox Name="InterfaceInfoBox" IsReadOnly="True"
                   AcceptsReturn="True" TextWrapping="Wrap"
                   FontFamily="Consolas" FontSize="13"/>
        </DockPanel>
      </Grid>
    </TabItem>

    <!-- ===================== ВКЛАДКА 2: Анализ URL ===================== -->
    <TabItem Header="Анализ URL / URI">
      <DockPanel Margin="5">

        <!-- Верхняя панель ввода -->
        <StackPanel DockPanel.Dock="Top" Spacing="8">
          <TextBlock Text="Введите URL:" FontWeight="Bold"/>
          <Grid ColumnDefinitions="*,10,Auto,10,Auto,10,Auto">
            <TextBox Name="UrlTextBox" Grid.Column="0" Watermark="https://example.com:8080/path?q=1#frag"/>
            <Button Grid.Column="2" Content="Разобрать URL"  Click="ParseUrl_Click"/>
            <Button Grid.Column="4" Content="Ping"           Click="PingHost_Click"/>
            <Button Grid.Column="6" Content="DNS"            Click="DnsLookup_Click"/>
          </Grid>
        </StackPanel>

        <!-- История -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="3" Margin="0,8,0,0">
          <TextBlock Text="История запросов:" FontWeight="Bold"/>
          <ListBox Name="HistoryListBox" Height="120"
                   DoubleTapped="HistoryListBox_DoubleTapped"/>
        </StackPanel>

        <!-- Результаты -->
        <TextBox Name="UrlResultBox" Margin="0,8,0,0"
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                 FontFamily="Consolas" FontSize="13"/>
      </DockPanel>
    </TabItem>

  </TabControl>
</Window>
